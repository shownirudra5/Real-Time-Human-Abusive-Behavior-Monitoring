# --- CONFIGURATION ---
DATASET_ROOT = r"C:\Users\stitli\Downloads\archive\dataset-video-split"
EPOCHS = 30
BATCH_SIZE = 8
TARGET_FRAMES = 30  # Normalize all videos to 30 frames
DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'

# Define your 21 Classes
CLASS_MAP = {
    'Vandalism': 0, 'Stealing': 1, 'Shoplifting': 2, 'Shooting': 3,
    'Robbery': 4, 'Roadaccidents': 5, 'Normal': 6, 'Walking': 7,
    'Walking_While_Using_Phone': 8, 'Walking_While_Reading_Book': 9,
    'Standing_Still': 10, 'Sitting': 11, 'Fighting': 12, 'Explosion': 13,
    'Meet_and_Split': 14, 'Burglary': 15, 'Clapping': 16, 'Assault': 17,
    'Arson': 18, 'Arrest': 19, 'Abuse': 20
}

class SkeletonExtractor:
    """Extract REAL skeleton sequences using YOLOv8-Pose"""
    
    def __init__(self, device='cuda'):
        self.device = device
        # LOAD THE POSE MODEL (Downloads automatically if missing)
        print(f"Loading YOLOv8-Pose model on {device}...")
        self.model = YOLO('yolov8n-pose.pt') 
        
    def process_video(self, video_path, target_frames=30):
        cap = cv2.VideoCapture(str(video_path))
        if not cap.isOpened():
            return None
        
        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        if total_frames < 1: 
            cap.release()
            return None

        # Uniform sampling
        frame_indices = np.linspace(0, total_frames - 1, target_frames, dtype=int)
        skeleton_sequence = []
        
        for frame_idx in frame_indices:
            cap.set(cv2.CAP_PROP_POS_FRAMES, frame_idx)
            ret, frame = cap.read()
            if not ret: break

            # Run YOLOv8 Pose Inference
            results = self.model(frame, verbose=False, device=self.device)
            
            # Extract Keypoints
            if results[0].keypoints is not None and results[0].keypoints.shape[1] > 0:
                # Get Normalized (x,y) and Confidence
                # Shape: (N_people, 17, 2)
                kpts_xy = results[0].keypoints.xyn.cpu().numpy() 
                kpts_conf = results[0].keypoints.conf.cpu().numpy()
                
                # Logic: Pick the person with highest average confidence (Main Actor)
                if len(kpts_conf) > 0:
                    best_person_idx = np.argmax(np.mean(kpts_conf, axis=1))
                    
                    # Prepare (17, 3) vector: [x, y, conf]
                    xy = kpts_xy[best_person_idx]      # (17, 2)
                    conf = kpts_conf[best_person_idx]  # (17,)
                    conf = conf.reshape(17, 1)
                    
                    person_kpts = np.hstack([xy, conf]) # (17, 3)
                    skeleton_sequence.append(person_kpts)
                else:
                    skeleton_sequence.append(np.zeros((17, 3)))
            else:
                skeleton_sequence.append(np.zeros((17, 3)))
        
        cap.release()
        
        # Pad or Truncate to ensure exact target_frames
        skeleton_sequence = np.array(skeleton_sequence)
        if len(skeleton_sequence) < target_frames:
            # Pad with zeros if video was too short/failed
            padding = np.zeros((target_frames - len(skeleton_sequence), 17, 3))
            skeleton_sequence = np.vstack([skeleton_sequence, padding]) if len(skeleton_sequence) > 0 else np.zeros((target_frames, 17, 3))
            
        return skeleton_sequence

class ActionDataset(Dataset):
    def __init__(self, skeletons, labels):
        self.skeletons = torch.FloatTensor(skeletons)
        self.labels = torch.LongTensor(labels)
    
    def __len__(self):
        return len(self.labels)
    
    def __getitem__(self, idx):
        # Permute for ST-GCN: (Channels, Time, Vertices) -> (3, 30, 17)
        return self.skeletons[idx].permute(2, 0, 1), self.labels[idx]

class STGCNBlock(nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.gcn = nn.Conv2d(in_channels, out_channels, kernel_size=(1, 1))
        self.tcn = nn.Sequential(
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_channels, out_channels, kernel_size=(9, 1), padding=(4, 0)),
            nn.BatchNorm2d(out_channels),
            nn.Dropout(0.1)
        )
        self.residual = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, kernel_size=1),
            nn.BatchNorm2d(out_channels)
        ) if in_channels != out_channels else lambda x: x
        self.relu = nn.ReLU(inplace=True)

    def forward(self, x):
        return self.relu(self.tcn(self.gcn(x)) + self.residual(x))

class STGCN(nn.Module):
    def __init__(self, num_classes=21):
        super().__init__()
        # Input: 3 channels (x,y,conf), 17 joints
        self.net = nn.Sequential(
            STGCNBlock(3, 64),
            STGCNBlock(64, 128),
            STGCNBlock(128, 256),
            STGCNBlock(256, 256)
        )
        self.fcn = nn.Conv1d(256, num_classes, kernel_size=1)

    def forward(self, x):
        N, C, T, V = x.size()
        x = self.net(x)
        x = x.mean(dim=3)  # Pool over vertices
        x = x.mean(dim=2, keepdim=True) # Pool over time
        x = self.fcn(x)
        return x.view(N, -1)

def load_data_from_folder(folder_path, extractor):
    """Iterates through a folder and assigns labels based on filename"""
    skeletons = []
    labels = []
    files = list(Path(folder_path).glob('**/*.*')) # Recursive search
    
    print(f"Scanning {folder_path}...")
    
    for f in tqdm(files):
        if f.suffix.lower() not in ['.mp4', '.avi', '.mov']:
            continue
            
        # Determine Label from Filename
        found_label = None
        fname = f.name.lower()
        
        # Check against our class map
        for class_name, class_id in CLASS_MAP.items():
            # Check if class name exists in filename (e.g., "Arson001.mp4")
            if class_name.lower() in fname:
                found_label = class_id
                break
        
        if found_label is not None:
            skel = extractor.process_video(f)
            if skel is not None:
                skeletons.append(skel)
                labels.append(found_label)
    
    return np.array(skeletons), np.array(labels)

def main():
    print(f"🚀 Starting 21-Class Action Recognition Training")
    
    # 1. Setup Data
    extractor = SkeletonExtractor(DEVICE)
    
    train_path = os.path.join(DATASET_ROOT, 'train')
    valid_path = os.path.join(DATASET_ROOT, 'valid')
    
    print("\n--- Phase 1: Feature Extraction ---")
    X_train, y_train = load_data_from_folder(train_path, extractor)
    X_val, y_val = load_data_from_folder(valid_path, extractor)
    
    print(f"\nTraining Samples: {len(y_train)} | Validation Samples: {len(y_val)}")
    
    # Save features locally so you don't have to re-extract next time
    np.save('X_train.npy', X_train)
    np.save('y_train.npy', y_train)
    np.save('X_val.npy', X_val)
    np.save('y_val.npy', y_val)

    # 2. Setup Model
    train_loader = DataLoader(ActionDataset(X_train, y_train), batch_size=BATCH_SIZE, shuffle=True)
    val_loader = DataLoader(ActionDataset(X_val, y_val), batch_size=BATCH_SIZE, shuffle=False)
    
    model = STGCN(num_classes=21).to(DEVICE)
    optimizer = optim.Adam(model.parameters(), lr=0.001)
    criterion = nn.CrossEntropyLoss()
    
    # 3. Training Loop
    print("\n--- Phase 2: Training ---")
    best_acc = 0.0
    
    for epoch in range(EPOCHS):
        model.train()
        train_loss = 0
        correct = 0
        total = 0
        
        for x, y in train_loader:
            x, y = x.to(DEVICE), y.to(DEVICE)
            optimizer.zero_grad()
            out = model(x)
            loss = criterion(out, y)
            loss.backward()
            optimizer.step()
            
            train_loss += loss.item()
            _, pred = out.max(1)
            correct += pred.eq(y).sum().item()
            total += y.size(0)
            
        # Validation
        model.eval()
        val_correct = 0
        val_total = 0
        with torch.no_grad():
            for x, y in val_loader:
                x, y = x.to(DEVICE), y.to(DEVICE)
                out = model(x)
                _, pred = out.max(1)
                val_correct += pred.eq(y).sum().item()
                val_total += y.size(0)
                
        val_acc = 100 * val_correct / val_total if val_total > 0 else 0
        train_acc = 100 * correct / total if total > 0 else 0
        
        print(f"Epoch {epoch+1}/{EPOCHS} | Loss: {train_loss/len(train_loader):.4f} | Train Acc: {train_acc:.1f}% | Val Acc: {val_acc:.1f}%")
        
        if val_acc > best_acc:
            best_acc = val_acc
            torch.save(model.state_dict(), 'best_model_21class.pth')
            print("  --> Model Saved!")

if __name__ == "__main__":
    main()